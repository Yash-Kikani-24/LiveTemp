# ============================================================================
# .env.example — environment variable template for the Live Strategy Alert Engine
# ============================================================================
# Copy this file to ".env" and fill in REAL values there. Never commit .env.
# Both processes (Engine = main.py, FastAPI = api.py) read these via
# systemd EnvironmentFile=.../.env (see webinfo.txt section 6).
#
# No real secrets belong in this file — these are placeholders only.
# ============================================================================

# --- Neon Postgres -----------------------------------------------------------
# Full async connection string for the Neon database (see schema.sql).
# Use Neon's connection string; sslmode=require is mandatory for Neon.
# NOTE: NOTIFY/LISTEN is NOT used (webinfo.txt 2.2), so the default POOLED
# connection string is fine here.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# --- Telegram alerts (sent by FastAPI) ---------------------------------------
# Bot token from @BotFather. Keep secret.
TELEGRAM_BOT_TOKEN=123456789:REPLACE_WITH_YOUR_BOT_TOKEN
# Target chat/channel/group ID the alerts are delivered to.
TELEGRAM_CHAT_ID=-1000000000000

# --- Engine -> FastAPI internal call (webinfo.txt 3.3 / 4) -------------------
# Same-machine localhost call; bypasses Nginx entirely. The Runner POSTs fired
# signals to this base URL (e.g. <base>/internal/signal).
FASTAPI_INTERNAL_URL=http://127.0.0.1:8000

# --- Node backend bias API (strategy GATE 2, fetched live on each setup) -----
# Base URL of the existing Node/Express backend. The CRT strategy calls
# <base>/api/bias/dailyClose?symbol=... when a setup is found. Set to the Render
# URL (https://<service>.onrender.com) in production.
NODE_BACKEND_URL=http://localhost:3001

# --- CORS (FastAPI must allow the Vercel frontend origin; webinfo.txt 5.5) ---
# The exact deployed Vercel origin, scheme included, NO trailing slash.
# Lock this to the specific origin (unlike the existing Express backend's "*").
# Accepts a comma-separated list (e.g. the Vercel origin plus localhost dev ports).
CORS_ALLOWED_ORIGIN=https://your-app.vercel.app,http://localhost:3000,http://localhost:5173
